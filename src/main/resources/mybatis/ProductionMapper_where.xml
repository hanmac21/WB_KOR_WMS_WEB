	<sql id="searchCondition_wipStock">
		<if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
		    <![CDATA[
		    AND (
		    (SDATE LIKE #{searchParams.toDate} || '%' AND KIND = 'INVENTORY')	OR (SDATE LIKE #{searchParams.fromDate} || '%' AND KIND <> 'INVENTORY')
			)
			]]>
		</if>
	    <if test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
	        AND UPPER(TRIM(factory)) = UPPER(TRIM(#{searchParams.factory}))
	    </if>
	    <!-- 창고: all 이면 무시 -->
	    <if test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'all'">
	        AND UPPER(TRIM(storage)) LIKE '%' || UPPER(TRIM(#{searchParams.storage})) || '%'
	    </if>
	    <if test="searchParams.itemcode != null and searchParams.itemcode != ''">
	        AND UPPER(TRIM(a.itemcode)) LIKE '%' || UPPER(TRIM(#{searchParams.itemcode})) || '%'
	    </if>
	    <if test="searchParams.itemname != null and searchParams.itemname != ''">
	        AND UPPER(TRIM(b.itemname)) LIKE '%' || UPPER(TRIM(#{searchParams.itemname})) || '%'
	    </if>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="searchCondition_production">
 		<choose>
	        <when test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
	            AND UPPER(a.factory) = UPPER(#{searchParams.factory})
	        </when>
	        <when test="searchParams.factory == null or searchParams.factory == ''">
	            AND UPPER(a.factory) = 'SALTILLO'
	        </when>
	    </choose>
	    
	    <if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
	        AND a.sdate BETWEEN #{searchParams.fromDate} AND #{searchParams.toDate}
	    </if>
	    
	    <if test="searchParams.car != null and searchParams.car != ''">
	        AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{searchParams.car}) || '%'
	    </if>
	    
	    <if test="searchParams.itemcode != null and searchParams.itemcode != ''">
	        AND UPPER(a.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
	    </if>
	
	    <if test="searchParams.itemname != null and searchParams.itemname != ''">
	        AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.itemname}, ' ', '')) || '%'
	    </if>
	    
	    <if test="searchParams.lineno != null and searchParams.lineno != ''">
	        AND UPPER(REPLACE(d.lineno, ' ', '')) = UPPER(#{searchParams.lineno})
	    </if>
	    
	    <if test="searchParams.workCenter != null and searchParams.workCenter != ''">
	        AND UPPER(REPLACE(d.workplace, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.workCenter}, ' ', '')) || '%'
	    </if>
	    
	    <if test="searchParams.okyn != null and searchParams.okyn != '' and searchParams.okyn !='ALL'">
	        AND UPPER(a.okyn) = UPPER(#{searchParams.okyn})
	    </if>
	</sql>	
	
