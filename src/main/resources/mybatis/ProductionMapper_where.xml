	<sql id="where_exceptionInput">
		<if test="intf_yn != null and intf_yn != '' and intf_yn != 'all'">
			AND a.intf_yn = #{intf_yn}
		</if>
		
		<choose>
         	<when test="factory != null and factory != '' and factory != 'all'">
               AND UPPER(a.factory) = UPPER(#{factory})
           	</when>
           	<when test="factory == null or factory == ''">
                AND UPPER(a.factory) = 'SALTILLO'
            </when>
            <otherwise>
                <!-- factory == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
            </otherwise>
        </choose>
            
        <choose>
            <when test="storage != null and storage != '' and storage != 'all'">
                AND UPPER(a.storage) = UPPER(#{storage})
            </when>
            <when test="storage == null or storage == ''">
                AND UPPER(a.storage) = UPPER('H/REST')
            </when>
            <otherwise>
                <!-- storage == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
            </otherwise>
        </choose>
        <choose>
		    <when test="fromDate != null and fromDate != '' and toDate != null and toDate != ''">
		        AND a.indate BETWEEN #{fromDate} AND #{toDate}
		    </when>
		    <otherwise>
		        AND a.indate BETWEEN TO_CHAR(SYSDATE - 7, 'YYYY-MM-DD') AND TO_CHAR(SYSDATE, 'YYYY-MM-DD')
		    </otherwise>
		</choose>
		
		<!-- 거래처코드 -->
		<if test="custcode != null and custcode != ''">
		  AND UPPER(a.custcode) LIKE '%' || #{custcode} || '%' 
		</if>
		
		<!-- 차종 (부분일치) -->
		<if test="car != null and car != ''">
		  AND UPPER(c.subname_ch) LIKE '%' || #{car} || '%'
		</if>
		
		<!-- 품번 (부분일치) -->
		<if test="itemcode != null and itemcode != ''">
		  AND UPPER(a.itemcode) LIKE '%' || UPPER(#{itemcode}) || '%'
		</if>
		
		<!-- 품명 (부분일치) -->
		<if test="itemname != null and itemname != ''">
		  <!-- AND UPPER(b.itemname) LIKE '%' || #{itemname} || '%' -->
		  AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{itemname}, ' ', '')) || '%'
		</if>	
	</sql>	
