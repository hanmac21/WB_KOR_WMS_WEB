	<sql id="where_unloadList">
		<choose>
			<when test="factory != null and factory != '' and factory != 'all'">
				AND UPPER(a.factory) = #{factory}
			</when>
			<when test="factory == null or factory == ''">
				AND UPPER(a.factory) = 'SALTILLO'
			</when>
			<otherwise>
            	<!-- factory == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
            </otherwise>
		</choose>
        <choose>
        	<when test="storage != null and storage != '' and storage != 'all'">
        		AND UPPER(a.storage) = UPPER(#{storage})
			</when>
			<when test="storage == null or storage == ''">
            	AND UPPER(a.storage) = UPPER('H/REST')
			</when>
			<otherwise>
            	<!-- storage == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
        	</otherwise>
		</choose>
		<if test="fromDate != null and fromDate != '' and toDate != null and toDate != '' ">
			AND a.indate between #{fromDate} and  #{toDate}
		</if>
