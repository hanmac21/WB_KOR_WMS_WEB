	<sql id="where_stock">
		<choose>
			<when test="factory != null and factory != '' and factory.toUpperCase() != 'ALL'">
            	AND UPPER(a.factory) = UPPER(#{factory})
			</when>
            <when test="factory == null or factory == ''">
                AND UPPER(a.factory) = 'SALTILLO'
            </when>
            <otherwise>
                <!-- factory == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
            </otherwise>
        </choose>
            
        <choose>
            <when test="storage != null and storage != '' and storage.toUpperCase() != 'ALL'">
				AND UPPER(a.storage) = UPPER(#{storage})
            </when>
            <when test="storage == null or storage == ''">
				AND UPPER(a.storage) = 'H/REST'
			</when>
            <otherwise>
                <!-- storage == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
            </otherwise>
        </choose>
            
        <if test="indate != null and indate != ''">
            AND a.indate = #{indate}
        </if>
         
        <if test="barcode != null and barcode != ''">
			AND UPPER(a.barcode) LIKE '%' || UPPER(#{barcode}) || '%'
		</if>

        <if test="location != null and location != ''">
			AND UPPER(a.location) LIKE '%' || UPPER(#{location}) || '%'
		</if>

        <if test="location_info != null and location_info != ''">
			AND UPPER(l.location) LIKE '%' || UPPER(#{location_info}) || '%'
		</if>

		<if test="car != null and car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{car}) || '%'
		</if>

		<if test="itemcode != null and itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || UPPER(#{itemcode}) || '%'
		</if>

		<if test="itemname != null and itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{itemname}, ' ', '')) || '%'
		</if>		
	</sql>	
