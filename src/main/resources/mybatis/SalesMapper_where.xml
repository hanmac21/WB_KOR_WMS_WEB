<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.wbusa.SalesMapper">
	<!-- ===================================================================================================================================================================== -->
	<sql id="searchCondition_incoming">
		<choose>
			<when test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
				AND UPPER(a.factory) = UPPER(#{searchParams.factory})
			</when>
			<when test="searchParams.factory == null or searchParams.factory == ''">
				AND UPPER(a.factory) = 'SALTILLO'
			</when>
		</choose>

		<choose>
			<when test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'all'">
				AND UPPER(a.storage) = UPPER(#{searchParams.storage})
			</when>
			<when test="searchParams.storage == null or searchParams.storage == ''">
				AND UPPER(a.storage) = 'MATERIAL'
			</when>
		</choose>

		<if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
			AND a.sdate BETWEEN #{searchParams.fromDate} AND #{searchParams.toDate}
		</if>

		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{searchParams.car}) || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
		</if>

		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.itemname}, ' ', '')) || '%'
		</if>

		<choose>
			<when test="searchParams.source == 'STOCKCOUNT'">
				AND UPPER(a.source2) = 'STOCKCOUNT'
			</when>
			<when test="searchParams.source == 'EXCEPTION'">
				<![CDATA[
               AND a.source2 IS NOT NULL AND a.source2 <> 'STOCKCOUNT'
              ]]>
			</when>
			<otherwise>
			</otherwise>
		</choose>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="searchCondition_load">
		<choose>
			<when test="searchParams.intf_yn == null  or searchParams.intf_yn == ''  or searchParams.intf_yn.toUpperCase() == 'ALL'">
			</when>
			<when test='searchParams.intf_yn == "Y"'>
				AND a.intf_yn = 'Y'
			</when>
			<otherwise>
				AND a.intf_yn != 'Y'
			</otherwise>
		</choose>

		<choose>
			<when test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
				AND UPPER(a.factory) = UPPER(#{searchParams.factory})
			</when>
			<when test="searchParams.factory == null or searchParams.factory == ''">
				AND UPPER(a.factory) = 'SALTILLO'
			</when>
		</choose>

		<choose>
			<when test="searchParams.storage != null and searchParams.storage.toUpperCase() == 'MATERIAL+SIDESEAT+OUTSIDE'">
				AND UPPER(a.storage) IN ('MATERIAL', 'SIDE SEAT', 'OUTSIDE')
			</when>
			<when test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'all'">
				AND UPPER(a.storage) = UPPER(#{searchParams.storage})
			</when>
			<when test="searchParams.storage == null or searchParams.storage == ''">
				AND UPPER(a.storage) = 'MATERIAL'
			</when>
		</choose>

		<if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
			AND a.sdate BETWEEN #{searchParams.fromDate} AND #{searchParams.toDate}
		</if>

		<if test="searchParams.cucode != null and searchParams.cucode != ''">
			AND UPPER(
				NVL(
					a.custcode,
					(
						SELECT custcode
						FROM (
							SELECT custcode
							FROM T_SM_SALECUSTPRICE
							WHERE itemcode = a.itemcode
							ORDER BY condate DESC
						)
						WHERE ROWNUM = 1
					)
				)
			) LIKE '%' || UPPER(#{searchParams.cucode}) || '%'
		</if>
		<if test="searchParams.cname != null and searchParams.cname != ''">
			AND UPPER(
				NVL(
					a.custname,
					(
						SELECT cu_sangho
						FROM c_cust
						WHERE cu_code = (
							SELECT custcode
							FROM (
								SELECT custcode
								FROM T_SM_SALECUSTPRICE
								WHERE itemcode = a.itemcode
								ORDER BY condate DESC
							)
							WHERE ROWNUM = 1
						)
					)
				)
			) LIKE '%' || UPPER(#{searchParams.cname}) || '%'
		</if>
		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{searchParams.car}) || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
		</if>

		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.itemname}, ' ', '')) || '%'
		</if>

		<if test="searchParams.invoiceNo != null and searchParams.invoiceNo != ''">
			AND UPPER(a.invoiceno) LIKE '%' || UPPER(#{searchParams.invoiceNo}) || '%'
		</if>

		<choose>
			<when test="searchParams.source == 'STOCKCOUNT'">
				AND UPPER(a.invoiceno) = 'BARCODECOUNT'
			</when>
			<when test="searchParams.source == 'EXCEPTION'">
				<![CDATA[
               AND a.invoiceno <> 'BARCODECOUNT'
               ]]>
			</when>
			<otherwise>
			</otherwise>
		</choose>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="where_transfer">
		<!-- 날짜: OUTDATE (YYYYMMDD) vs input date (YYYY-MM-DD) -->
		<if test="searchParams.fromDate != null and searchParams.fromDate != ''">
			AND A.OUTDATE BETWEEN #{searchParams.fromDate} and #{searchParams.toDate}
		</if>
	
		<!-- OITEMCODE: SPEC 에서 '-' 제거 후 비교 -->
		<if test="searchParams.oitemcode != null and searchParams.oitemcode != ''">
			AND UPPER(REPLACE(TRIM(B.SPEC), '-', ''))
			    LIKE '%' || UPPER(TRIM(#{searchParams.oitemcode})) || '%'
		</if>
	
		<!-- CAR (차종) -->
		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(TRIM(C.SUBNAME_CH)) LIKE '%' || UPPER(TRIM(#{searchParams.car})) || '%'
		</if>
	
		<!-- ITEMCODE -->
		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(TRIM(A.ITEMCODE))
			    LIKE '%' || UPPER(TRIM(#{searchParams.itemcode})) || '%'
		</if>
	
		<!-- ITEMNAME -->
		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(TRIM(B.ITEMNAME))
			    LIKE '%' || UPPER(TRIM(#{searchParams.itemname})) || '%'
		</if>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="where_salesInvoice">
		<if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
			AND SDATE BETWEEN #{searchParams.fromDate} and #{searchParams.toDate}
		</if>
		
		<if test="searchParams.custname != null and searchParams.custname != ''">
			AND UPPER(TRIM(CUSTNAME)) LIKE '%' || UPPER(TRIM(#{searchParams.custname})) || '%'
		</if>
		
		<if test="searchParams.invoiceNo != null and searchParams.invoiceNo != ''">
			AND UPPER(TRIM(INVOICENO)) LIKE '%' || UPPER(TRIM(#{searchParams.invoiceNo})) || '%'
		</if>
		
		<if test="searchParams.factory != null and searchParams.factory != ''">
			AND UPPER(TRIM(SOURCE3)) LIKE '%' || UPPER(TRIM(#{searchParams.factory})) || '%'
		</if>
		
		<if test="searchParams.dock != null and searchParams.dock != ''">
			AND UPPER(TRIM(DOCK)) LIKE '%' || UPPER(TRIM(#{searchParams.dock})) || '%'
		</if>
		
		<if test="searchParams.containerNo != null and searchParams.containerNo != ''">
			AND UPPER(TRIM(CONTAINER)) LIKE '%' || UPPER(TRIM(#{searchParams.containerNo})) || '%'
		</if>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="searchCondition_storage">
		<if test="searchParams.intf_yn != null and searchParams.intf_yn != '' and searchParams.intf_yn != 'all'">
			AND a.intf_yn = #{searchParams.intf_yn}
		</if>

		<choose>
			<when test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
				AND UPPER(a.factory) = UPPER(#{searchParams.factory})
			</when>
			<when test="searchParams.factory == null or searchParams.factory == ''">
				AND UPPER(a.factory) = 'SALTILLO'
			</when>
		</choose>

		<choose>
			<when test="searchParams.storage1 != null and searchParams.storage1 != '' and searchParams.storage1 != 'all'">
				AND UPPER(a.storage1) = UPPER(#{searchParams.storage1})
			</when>
			<when test="searchParams.storage1 == null or searchParams.storage1 == ''">
				AND UPPER(a.storage1) = 'MATERIAL'
			</when>
		</choose>

		<choose>
			<when test="searchParams.storage2 != null and searchParams.storage2 != '' and searchParams.storage2 != 'all'">
				AND UPPER(a.storage2) = UPPER(#{searchParams.storage2})
			</when>
			<when test="searchParams.storage2 == null or searchParams.storage2 == ''">
				AND UPPER(a.storage2) = 'MATERIAL'
			</when>
		</choose>

		<if test="searchParams.fromDate != null and searchParams.fromDate != '' and searchParams.toDate != null and searchParams.toDate != ''">
			AND a.sdate BETWEEN #{searchParams.fromDate} AND #{searchParams.toDate}
		</if>

		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{searchParams.car}) || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
		</if>

		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.itemname}, ' ', '')) || '%'
		</if>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="order_stockDetail">
		<choose>
			<when test="'FACTORY'.equals(sortKey)">X.FACTORY</when>
			<when test="'STORAGE'.equals(sortKey)">X.STORAGE</when>
			<when test="'SDATE'.equals(sortKey)">X.SDATE</when>
			<when test="'CAR'.equals(sortKey)">X.CAR</when>
			<when test="'ITEMCODE'.equals(sortKey)">X.ITEMCODE</when>
			<when test="'SPEC'.equals(sortKey)">X.SPEC</when>
			<when test="'ITEMNAME'.equals(sortKey)">X.ITEMNAME</when>
			<when test="'LOCATION'.equals(sortKey)">X.LOCATION</when>
			<when test="'QTY'.equals(sortKey)">X.QTY</when>
			<when test="'LOGINID'.equals(sortKey)">X.LOGINID</when>
			<when test="'HHMM'.equals(sortKey)">X.HHMM</when>
			<when test="'BARCODE'.equals(sortKey)">X.BARCODE</when>
			<when test="'YMDHMS'.equals(sortKey)">X.YMDHMS</when>
			<when test="'MADATE'.equals(sortKey)">X.MADATE</when>
			<otherwise>X.YMDHMS</otherwise>
		</choose>

		<choose>
			<when test="'ASC'.equals(sortDir) or 'asc'.equals(sortDir)">ASC</when>
			<otherwise>DESC</otherwise>
		</choose>

		, X.ITEMCODE ASC
	</sql>

	<sql id="where_stock">
		<choose>
			<when test="factory != null and factory != '' and factory.toUpperCase() != 'ALL'">
				AND UPPER(a.factory) = UPPER(#{factory})
			</when>
			<when test="factory == null or factory == ''">
				AND UPPER(a.factory) = 'WBTA'
			</when>
			<otherwise>
				<!-- factory == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
			</otherwise>
		</choose>

		<choose>
			<when test="storage != null and storage != '' and storage.toUpperCase() != 'ALL'">
				AND UPPER(a.storage) = UPPER(#{storage})
			</when>
			<when test="storage == null or storage == ''">
				AND UPPER(a.storage) = UPPER('MATERIAL')
			</when>
			<otherwise>
				<!-- storage == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
			</otherwise>
		</choose>

		<if test="sdate != null and sdate != ''">
			AND a.sdate = #{sdate}
		</if>

		<if test="barcode != null and barcode != ''">
			AND UPPER(a.barcode) LIKE '%' || UPPER(#{barcode}) || '%'
		</if>

		<if test="location != null and location != ''">
			AND UPPER(a.location) LIKE '%' || UPPER(#{location}) || '%'
		</if>

		<if test="location_info != null and location_info != ''">
			AND UPPER(l.location) LIKE '%' || UPPER(#{location_info}) || '%'
		</if>

		<if test="car != null and car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || UPPER(#{car}) || '%'
		</if>

		<if test="itemcode != null and itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || UPPER(#{itemcode}) || '%'
		</if>

		<if test="itemname != null and itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{itemname}, ' ', '')) || '%'
		</if>
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="order_stockSummary">
		ORDER BY
		<choose>
			<when test="sortKey == 'FACTORY'">FACTORY</when>
			<when test="sortKey == 'CAR'">CAR</when>
			<when test="sortKey == 'ITEMCODE'">ITEMCODE</when>
			<when test="sortKey == 'ITEMNAME'">ITEMNAME</when>
			<when test="sortKey == 'SPEC'">SPEC</when>
			<when test="sortKey == 'QTY'">QTY</when>
			<when test="sortKey == 'NOQTY1'">NOQTY1</when>
			<when test="sortKey == 'NOQTY2'">NOQTY2</when>
			<when test="sortKey == 'NOQTY3'">NOQTY3</when>
			<when test="sortKey == 'UNPACKQTY'">UNPACKQTY</when>
			<otherwise>ITEMCODE</otherwise>
		</choose>
		<choose>
			<when test="sortDir != null and (sortDir == 'ASC' or sortDir == 'asc')">ASC</when>
			<otherwise>DESC</otherwise>
		</choose>
		, ITEMCODE ASC
	</sql>
	<!-- ===================================================================================================================================================================== -->
	<sql id="searchCondition_storageStock1">
		<if test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
			AND UPPER(TRIM(factory)) = UPPER(TRIM(#{searchParams.factory}))
		</if>
		<if test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'all'">
			AND UPPER(TRIM(storage)) = UPPER(TRIM(#{searchParams.storage}))
		</if>
	</sql>
	<sql id="searchCondition_storageStock2">
		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(TRIM(x.ITEMCODE)) LIKE '%' || UPPER(TRIM(#{searchParams.itemcode})) || '%'
		</if>

		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(TRIM(i.itemname)) LIKE '%' || UPPER(TRIM(#{searchParams.itemname})) || '%'
		</if>
	</sql>

	<sql id="where_realstock">
		<if test="searchParams.intf_yn != null and searchParams.intf_yn != '' and searchParams.intf_yn != 'all'">
			AND a.intf_yn = #{searchParams.intf_yn}
		</if>
		<choose>
			<when test="searchParams.scantype != null and searchParams.scantype != '' and searchParams.scantype != 'all'">
				AND a.scantype = #{searchParams.scantype}
			</when>
			<otherwise>
			</otherwise>
		</choose>

		<choose>
			<when test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'all'">
				AND UPPER(a.factory) = UPPER(#{searchParams.factory})
			</when>
			<when test="searchParams.factory == null or searchParams.factory == ''">
				AND UPPER(a.factory) = 'WBTA'
			</when>
			<otherwise>
				<!-- factory == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
			</otherwise>
		</choose>

		<if test="searchParams.sdate != null and searchParams.sdate != ''">
			AND a.sdate = #{searchParams.sdate}
		</if>

		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(c.subname_ch) LIKE '%' || #{searchParams.car} || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(a.itemcode) LIKE '%' || #{searchParams.itemcode} || '%'
		</if>

		<if test="searchParams.itemname != null and searchParams.itemname != ''">
			AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{searchParams.itemname}, ' ', '')) || '%'
		</if>

		<if test="searchParams.location != null and searchParams.location != ''">
			AND UPPER(a.location) LIKE '%' || #{searchParams.location} || '%'
		</if>

		<if test="searchParams.loginid != null and searchParams.loginid != ''">
			AND UPPER(a.loginid) LIKE '%' || #{searchParams.loginid} || '%'
		</if>
	</sql>

	<sql id="where_stockCountMissing_location_top">
		<if test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'ALL'">
			AND UPPER(r.factory) = UPPER(#{searchParams.factory})
		</if>

		<if test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'all'">
			AND UPPER(r.storage) = UPPER(#{searchParams.storage})
		</if>

		<if test="searchParams.location != null and searchParams.location != ''">
			AND UPPER(r.location) LIKE '%' || UPPER(#{searchParams.location}) || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(r.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
		</if>
		<if test="searchParams.startdate != null and searchParams.startdate != ''">
			<![CDATA[and r.sdate = #{searchParams.startdate}]]>
			<![CDATA[and l.sdate <= #{searchParams.startdate}]]>
		</if>
	</sql>

	<sql id="where_stockCountMissing_location">
		<if test="searchParams.factory != null and searchParams.factory != '' and searchParams.factory != 'ALL'">
			AND UPPER(l.factory) = UPPER(#{searchParams.factory})
		</if>

		<if test="searchParams.storage != null and searchParams.storage != '' and searchParams.storage != 'ALL'">
			AND UPPER(l.storage) = UPPER(#{searchParams.storage})
		</if>

		<if test="searchParams.location != null and searchParams.location != ''">
			AND UPPER(l.location) LIKE '%' || UPPER(#{searchParams.location}) || '%'
		</if>

		<if test="searchParams.itemcode != null and searchParams.itemcode != ''">
			AND UPPER(l.itemcode) LIKE '%' || UPPER(#{searchParams.itemcode}) || '%'
		</if>

		<if test="searchParams.car != null and searchParams.car != ''">
			AND UPPER(l.car) LIKE '%' || UPPER(#{searchParams.car}) || '%'
		</if>
		<if test="searchParams.startdate != null and searchParams.startdate != ''">
			<![CDATA[
				AND l.sdate <= #{searchParams.startdate}
				AND l.BACKUP_DATE LIKE '%' || #{searchParams.startdate} || '%'
			]]>
		</if>
	</sql>

	<sql id = "where_erpInterfaceSummary">
		<if test="factory != null and factory != '' and factory != 'ALL'">
			AND UPPER(factory) = UPPER(#{factory})
		</if>

		<choose>
			<when test="storage != null and storage != '' and storage != 'all'">
				AND UPPER(storage) = UPPER(#{storage})
			</when>
			<when test="storage == null or storage == ''">
				AND UPPER(storage) = UPPER('Material')
			</when>

			<otherwise>
				<!-- storage == 'all'인 경우: 조건 추가 안함 (전체 조회) -->
			</otherwise>
		</choose>

		<if test="itemcode != null and itemcode != ''">
			AND UPPER(itemcode) LIKE '%' || UPPER(#{itemcode}) || '%'
		</if>

		<if test="startdate != null and startdate != ''">
			<![CDATA[and sdate = #{startdate}]]>
		</if>
	</sql>

	<sql id="where_erpInterfaceSummary2">
		<if test="factory != null and factory != '' and factory != 'ALL'">
			AND UPPER(l.factory) = UPPER(#{factory})
		</if>

		<if test="storage != null and storage != '' and storage != 'ALL'">
			AND UPPER(l.storage) = UPPER(#{storage})
		</if>

		<if test="location != null and location != ''">
			AND UPPER(l.location) LIKE '%' || UPPER(#{location}) || '%'
		</if>

		<if test="itemcode != null and itemcode != ''">
			AND UPPER(l.itemcode) LIKE '%' || UPPER(#{itemcode}) || '%'
		</if>

		<if test="car != null and car != ''">
			AND UPPER(l.car) LIKE '%' || UPPER(#{car}) || '%'
		</if>
		<if test="startdate != null and startdate != ''">
			<![CDATA[
				AND l.sdate <= #{startdate}
				AND l.BACKUP_DATE LIKE '%' || #{startdate} || '%'
			]]>
		</if>
	</sql>

	<sql id = "where_erpInterfaceSummary3">
		<if test="factory != null and factory != '' and factory != 'ALL'">
			AND UPPER(factory) = UPPER(#{factory})
		</if>
		<if test="itemcode != null and itemcode != ''">
			AND itemcode LIKE '%' || #{itemcode} || '%'
		</if>
		<if test="itemname != null and itemname != ''">
			AND itemname LIKE '%' || #{itemname} || '%'
		</if>
		<if test="car != null and car != ''">
			AND car LIKE '%' || #{car} || '%'
		</if>
	</sql>

</mapper> 