	<sql id="qualityDashboardCommonWhere">
		WHERE factory IS NOT NULL
		AND useyn = 'Y'
		<if test="factory != null and factory != '' and factory != 'ALL'">
			AND UPPER(factory) = UPPER(#{factory})
		</if>
		<if test="sdate != null and sdate != ''">
			AND sdate = #{sdate}
		</if>
		<if test="source != null and source != '' and source != 'ALL'">
			AND UPPER(source) = UPPER(#{source})
		</if>
	</sql>

	<sql id="qualityDashboardCommonWhereForSummary">
		WHERE factory IS NOT NULL
		AND useyn = 'Y'
		<if test="factory != null and factory != '' and factory != 'ALL'">
			AND UPPER(factory) = UPPER(#{factory})
		</if>
		<if test="sdate != null and sdate != ''">
			AND sdate = #{sdate}
		</if>
	</sql>
	<!-- ============================================================
     안전 숫자 변환
		============================================================ -->
	<sql id="qualitySafeQty">
		CASE
			WHEN TRIM(qty) IS NOT NULL
				AND REGEXP_LIKE(TRIM(qty), '^-?\d+(\.\d+)?$')
			THEN TO_NUMBER(TRIM(qty))
			ELSE 0
		END
	</sql>

	<sql id="qualitySafeOkQty">
		CASE
			WHEN TRIM(okqty) IS NOT NULL
				AND REGEXP_LIKE(TRIM(okqty), '^-?\d+(\.\d+)?$')
			THEN TO_NUMBER(TRIM(okqty))
			ELSE 0
		END
	</sql>

	<sql id="qualitySafeNgQty">
		CASE
			WHEN TRIM(ngqty) IS NOT NULL
				AND REGEXP_LIKE(TRIM(ngqty), '^-?\d+(\.\d+)?$')
			THEN TO_NUMBER(TRIM(ngqty))
			ELSE 0
		END
	</sql>
	
	
