<mapper namespace="com.example.demo.mapper.wbusa.DashboardMapper">
	
	
	<sql id="commonFilters_partsRequirement_incoming">
		AND a.source <![CDATA[<>]]> 'INCOMINGRETURN'
	    <if test="month != null and month != '' and month != 'all'">
	        AND a.indate between #{startDate} and #{endDate}
	    </if>
	    <if test="factory != null and factory != '' and factory != 'all'">
	        AND UPPER(REPLACE(a.factory, ' ', '')) = UPPER(REPLACE(#{factory}, ' ', ''))
	    </if>
	    <!-- storage -->
	    <choose>
	
	        <!-- ✅ storage가 지정된 경우 -->
	        <when test="storage != null and storage != '' and storage != 'all'">
	            <choose>
	                <when test="storage == 'MATERIAL+SIDESEAT+OUTSIDE'">
	                    AND UPPER(REPLACE(a.storage, ' ', '')) IN ('MATERIAL', 'SIDESEAT', 'OUTSIDE')
	                </when>
	                <otherwise>
	                    AND UPPER(REPLACE(a.storage, ' ', '')) = UPPER(REPLACE(#{storage}, ' ', ''))
	                </otherwise>
	            </choose>
	        </when>
	
	        <!-- ✅ storage = all 인 경우: factory별 허용 창고만 -->
	        <otherwise>
	            <choose>
	                <when test="factory != null and (factory == 'SALTILLO' or factory == 'saltillo')">
	                    AND UPPER(REPLACE(a.storage, ' ', '')) IN ('MATERIAL', 'FABRIC', 'SIDESEAT', 'OUTSIDE')
	                </when>
	
	                <when test="factory != null and (factory == 'PUEBLA' or factory == 'puebla')">
	                    AND UPPER(REPLACE(a.storage, ' ', '')) IN ('MATERIAL')
	                </when>
	
	                <!-- factory가 all/미지정이면(안전장치): 둘 다 합집합 -->
	                <otherwise>
	                    AND UPPER(REPLACE(a.storage, ' ', '')) IN ('MATERIAL', 'FABRIC', 'SIDESEAT', 'OUTSIDE')
	                </otherwise>
	            </choose>
	        </otherwise>
	
	    </choose>
	    <if test="partNumber != null and partNumber != '' and partNumber != 'all'">
	        AND UPPER(REPLACE(a.itemcode, ' ', '')) LIKE '%' || UPPER(REPLACE(#{partNumber}, ' ', '')) || '%'
	    </if>
	    <if test="partName != null and partName != '' and partName != 'all'">
	        AND UPPER(REPLACE(b.itemname, ' ', '')) LIKE '%' || UPPER(REPLACE(#{partName}, ' ', '')) || '%'
	    </if>
	</sql>
	
